<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Rip It Labs — RILbots Custom AI Agents</title>
<meta name="description" content="Rip It Labs builds RILbots — fully custom AI agents designed around your specific business workflows. Automate anything. Keep humans in control.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Barlow:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,300&family=Barlow+Condensed:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --black:       #050507;
  --deep:        #080809;
  --surface:     #0c0c0f;
  --surface-2:   #101014;
  --surface-3:   #141418;
  --blue:        #5a8fa8;
  --blue-mid:    #7eb8d4;
  --blue-bright: #a8d4e8;
  --blue-pale:   #cce6f2;
  --blue-glow:   rgba(126,184,212,0.15);
  --blue-faint:  rgba(126,184,212,0.05);
  --border:      rgba(160,190,220,0.1);
  --border-soft: rgba(255,255,255,0.05);
  --white:       #eef0f5;
  --silver:      #8898aa;
  --muted:       #3a4455;
  --display:     'Barlow Condensed', sans-serif;
  --body:        'Barlow', sans-serif;
  --mono:        'Share Tech Mono', monospace;
}

html { scroll-behavior: smooth; }
body {
  font-family: var(--body);
  background: var(--black);
  color: var(--white);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}

/* subtle scanline texture */
body::before {
  content: '';
  position: fixed; inset: 0; z-index: 1000; pointer-events: none;
  background-image: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 2px,
    rgba(0,0,0,0.08) 2px,
    rgba(0,0,0,0.08) 3px
  );
}

/* NAV */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  height: 64px;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 3rem;
  background: rgba(3,5,11,0.94);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
}
.nav-logo { display: flex; align-items: center; text-decoration: none; gap: 0.75rem; }
.nav-logo-icon { height: 36px; width: auto; }
.nav-logo-text {
  font-family: var(--display); font-weight: 700; font-size: 1.1rem;
  letter-spacing: 0.12em; text-transform: uppercase; color: var(--white);
  display: none;
}
.nav-links { display: flex; list-style: none; }
.nav-links a {
  color: var(--muted); text-decoration: none; font-family: var(--mono);
  font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase;
  padding: 0 1.1rem; height: 64px;
  display: flex; align-items: center;
  border-bottom: 1px solid transparent;
  transition: color 0.2s, border-color 0.2s;
}
.nav-links a:hover { color: var(--blue-bright); border-bottom-color: var(--blue-bright); }
.nav-right { display: flex; align-items: center; gap: 1.25rem; }
.nav-phone {
  font-family: var(--mono); font-size: 0.72rem; letter-spacing: 0.1em;
  color: var(--muted); text-decoration: none; transition: color 0.2s;
}
.nav-phone:hover { color: var(--blue-bright); }
.nav-cta {
  background: transparent; color: var(--blue-bright);
  border: 1px solid rgba(160,190,220,0.3); padding: 0.5rem 1.4rem;
  font-family: var(--mono); font-weight: 400; font-size: 0.72rem;
  letter-spacing: 0.12em; text-transform: uppercase; text-decoration: none;
  transition: background 0.2s, box-shadow 0.2s, color 0.2s;
  clip-path: polygon(6px 0%, 100% 0%, calc(100% - 6px) 100%, 0% 100%);
}
.nav-cta:hover {
  background: var(--blue-glow);
  box-shadow: 0 0 20px rgba(34,211,238,0.2), inset 0 0 20px rgba(34,211,238,0.05);
  color: #fff;
}

/* HERO */
.hero {
  min-height: 100vh;
  display: grid; grid-template-columns: 1fr 1fr;
  align-items: center; padding-top: 64px;
  position: relative; overflow: hidden;
}
.hero-bg {
  position: absolute; inset: 0; pointer-events: none;
  background:
    radial-gradient(ellipse 60% 60% at 85% 40%, rgba(126,184,212,0.1) 0%, transparent 60%),
    radial-gradient(ellipse 35% 40% at 5% 85%, rgba(100,140,170,0.05) 0%, transparent 55%),
    linear-gradient(160deg, #04060f 0%, #03050b 100%);
}
.hero-grid {
  position: absolute; inset: 0; pointer-events: none;
  background-image:
    linear-gradient(rgba(180,200,220,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(180,200,220,0.03) 1px, transparent 1px);
  background-size: 60px 60px;
  mask-image: radial-gradient(ellipse 80% 80% at 70% 50%, rgba(0,0,0,0.5) 0%, transparent 75%);
  -webkit-mask-image: radial-gradient(ellipse 80% 80% at 70% 50%, rgba(0,0,0,0.5) 0%, transparent 75%);
}
.hero-left {
  position: relative; z-index: 1;
  padding: 5rem 3rem 5rem 3rem;
}
.hero-tag {
  font-family: var(--mono); font-size: 0.68rem; letter-spacing: 0.2em;
  text-transform: uppercase; color: var(--blue-bright);
  margin-bottom: 1.75rem; display: flex; align-items: center; gap: 0.75rem;
}
.hero-tag::before {
  content: ''; display: block; width: 2rem; height: 1px; background: var(--blue-bright);
}
.hero-tag::after {
  content: ''; display: block; width: 4px; height: 4px;
  background: var(--blue-bright); border-radius: 50%;
  box-shadow: 0 0 6px rgba(168,212,232,0.8);
}
.hero h1 {
  font-family: var(--display); font-weight: 800;
  font-size: clamp(3.2rem, 6vw, 6rem);
  line-height: 0.95; letter-spacing: 0.02em; text-transform: uppercase;
  color: var(--white); margin-bottom: 0.5rem;
}
.hero h1 .rilbots {
  display: block;
  background: linear-gradient(100deg, #c8d0dc 0%, #e8eef4 50%, #ffffff 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
  filter: drop-shadow(0 0 30px rgba(34,211,238,0.4));
}
.hero-sub {
  font-size: 1rem; font-weight: 300; color: var(--silver);
  line-height: 1.8; max-width: 460px; margin-bottom: 2.5rem;
  margin-top: 1.5rem;
}
.hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; align-items: center; }

/* BUTTONS */
.btn-primary {
  background: linear-gradient(135deg, #8aafc8 0%, #b8cede 100%); color: #05070a;
  padding: 0.85rem 2.25rem;
  font-family: var(--mono); font-weight: 400; font-size: 0.78rem;
  letter-spacing: 0.12em; text-transform: uppercase;
  text-decoration: none; display: inline-block;
  clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%);
  box-shadow: 0 0 24px rgba(126,184,212,0.2);
  transition: background 0.2s, box-shadow 0.2s, transform 0.15s;
}
.btn-primary:hover {
  background: var(--blue-bright); box-shadow: 0 0 40px rgba(34,211,238,0.5);
  transform: translateY(-1px);
}
.btn-ghost {
  color: var(--silver); padding: 0.85rem 2rem;
  border: 1px solid var(--border-soft); font-family: var(--mono);
  font-size: 0.78rem; letter-spacing: 0.1em; text-transform: uppercase;
  text-decoration: none; display: inline-block;
  transition: color 0.2s, border-color 0.2s;
  clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%);
}
.btn-ghost:hover { color: var(--white); border-color: var(--border); }

/* HERO RIGHT */
.hero-right {
  position: relative; z-index: 1;
  display: flex; align-items: center; justify-content: center;
  height: 100%; padding: 5rem 3rem 5rem 0;
}
.hero-logo-wrap {
  position: relative; width: 100%; max-width: 540px;
  display: flex; align-items: center; justify-content: center;
}
.hero-logo-glow {
  position: absolute; inset: -25%;
  background: radial-gradient(ellipse 55% 45% at 50% 55%, rgba(160,192,210,0.12) 0%, transparent 70%);
  pointer-events: none;
  animation: pulseGlow 4s ease-in-out infinite;
}
@keyframes pulseGlow {
  0%, 100% { opacity: 0.7; }
  50% { opacity: 1; }
}
.hero-logo-img {
  width: 100%; max-width: 500px; opacity: 0.95;
  filter: drop-shadow(0 0 50px rgba(34,211,238,0.22)) drop-shadow(0 0 100px rgba(6,182,212,0.15));
  animation: floatLogo 7s ease-in-out infinite;
}
@keyframes floatLogo {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12px); }
}

/* STATS */
.stats {
  display: grid; grid-template-columns: repeat(4, 1fr);
  background: var(--deep);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}
.stat-item {
  padding: 2.25rem 2.5rem; border-right: 1px solid var(--border);
  position: relative; overflow: hidden;
  transition: background 0.2s;
}
.stat-item:last-child { border-right: none; }
.stat-item:hover { background: var(--surface); }
.stat-num {
  font-family: var(--display); font-weight: 800; font-size: 2.8rem;
  letter-spacing: 0.02em; text-transform: uppercase;
  color: var(--white); line-height: 1; margin-bottom: 0.4rem;
}
.stat-num .unit { color: var(--blue-bright); }
.stat-label { font-family: var(--body); font-size: 0.8rem; color: var(--muted); font-weight: 400; line-height: 1.45; }

/* SECTION BASE */
.section { padding: 7rem 3rem; }
.label {
  font-family: var(--mono); font-size: 0.66rem;
  letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--blue-bright); margin-bottom: 1rem;
  display: flex; align-items: center; gap: 0.75rem;
}
.label::before { content: '//'; opacity: 0.5; }
h2 {
  font-family: var(--display); font-weight: 800; font-size: clamp(2.2rem, 3.5vw, 3.2rem);
  letter-spacing: 0.04em; text-transform: uppercase;
  line-height: 1.05; margin-bottom: 1.25rem; color: var(--white);
}
h2 em { font-style: normal; color: var(--blue-bright); }

/* RILBOTS SECTION */
.rilbots-section {
  background: var(--deep);
  border-bottom: 1px solid var(--border);
  padding: 7rem 3rem;
}
.rilbots-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: center; }
.rilbots-name {
  font-family: var(--display); font-weight: 800;
  font-size: clamp(4rem, 7vw, 6.5rem);
  letter-spacing: 0.06em; text-transform: uppercase; line-height: 0.9;
  background: linear-gradient(110deg, #b0bcc8 0%, #dce4ec 55%, #ffffff 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text; margin-bottom: 0.4rem;
}
.rilbots-sub {
  font-family: var(--mono); font-size: 0.72rem; color: var(--muted);
  letter-spacing: 0.18em; text-transform: uppercase; margin-bottom: 2rem;
}
.rilbots-desc {
  color: var(--silver); font-size: 0.95rem; line-height: 1.8;
  font-weight: 300; margin-bottom: 1.5rem;
}
.rilbots-right {
  display: flex; flex-direction: column; gap: 1px;
  background: var(--border); border: 1px solid var(--border);
  clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
  overflow: hidden;
}
.rilbot-feature {
  background: var(--surface); padding: 1.6rem 2rem;
  display: grid; grid-template-columns: 2rem 1fr; gap: 1.25rem; align-items: start;
  transition: background 0.2s;
}
.rilbot-feature:hover { background: var(--surface-2); }
.feature-bullet {
  width: 6px; height: 6px; background: var(--blue-bright); border-radius: 50%;
  margin-top: 0.55rem; box-shadow: 0 0 8px rgba(168,212,232,0.6); flex-shrink: 0;
}
.rilbot-feature h4 {
  font-family: var(--display); font-weight: 700; font-size: 0.95rem;
  text-transform: uppercase; letter-spacing: 0.06em;
  color: var(--white); margin-bottom: 0.3rem;
}
.rilbot-feature p { font-size: 0.83rem; color: var(--muted); line-height: 1.6; font-weight: 300; }

/* MISSION */
.mission-section { padding: 7rem 3rem; border-bottom: 1px solid var(--border-soft); }
.mission-inner { display: grid; grid-template-columns: 1fr 1.5fr; gap: 7rem; align-items: start; }
.mission-quote {
  font-family: var(--display); font-weight: 600; font-size: clamp(1.3rem, 2vw, 1.75rem);
  line-height: 1.4; color: var(--white); letter-spacing: 0.02em; text-transform: uppercase;
  border-left: 2px solid var(--blue-mid); padding-left: 1.75rem; margin-bottom: 2rem;
}
.mission-quote em { font-style: normal; color: var(--blue-bright); }
.mission-body { color: var(--silver); font-size: 0.95rem; line-height: 1.85; font-weight: 300; }
.mission-pillars {
  display: grid; grid-template-columns: 1fr 1fr; gap: 1px;
  background: var(--border); border: 1px solid var(--border);
  clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
  overflow: hidden;
}
.pillar { background: var(--surface); padding: 1.75rem; transition: background 0.2s; }
.pillar:hover { background: var(--surface-2); }
.pillar-label {
  font-family: var(--display); font-weight: 700; font-size: 0.95rem;
  text-transform: uppercase; letter-spacing: 0.08em;
  color: var(--white); margin-bottom: 0.5rem;
  border-bottom: 1px solid var(--border); padding-bottom: 0.5rem;
}
.pillar p { font-size: 0.83rem; color: var(--muted); line-height: 1.6; font-weight: 300; margin-top: 0.5rem; }

/* SERVICES */
.services-section { background: var(--deep); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 7rem 3rem; }
.services-header { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; margin-bottom: 4rem; align-items: end; }
.services-desc { color: var(--silver); font-size: 0.95rem; line-height: 1.8; font-weight: 300; }
.services-grid {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 1px; background: var(--border); border: 1px solid var(--border); overflow: hidden;
  clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
}
.service-card {
  background: var(--surface); padding: 2.25rem;
  transition: background 0.25s; position: relative; overflow: hidden;
}
.service-card::after {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, rgba(200,215,230,0.4), transparent);
  transform: scaleX(0); transform-origin: center; transition: transform 0.35s ease;
}
.service-card:hover { background: var(--surface-2); }
.service-card:hover::after { transform: scaleX(1); }
.service-num {
  font-family: var(--mono); font-size: 0.66rem; color: var(--blue-bright);
  letter-spacing: 0.14em; margin-bottom: 1.25rem; display: block; opacity: 0.5;
}
.service-card h3 {
  font-family: var(--display); font-weight: 700; font-size: 1rem;
  letter-spacing: 0.06em; text-transform: uppercase;
  margin-bottom: 0.75rem; color: var(--white); line-height: 1.3;
}
.service-card p { font-size: 0.84rem; color: var(--muted); line-height: 1.7; font-weight: 300; }

/* HOW WE WORK */
.how-section { padding: 7rem 3rem; border-bottom: 1px solid var(--border-soft); }
.how-header { max-width: 580px; margin-bottom: 4rem; }
.how-header p { color: var(--silver); font-size: 0.95rem; line-height: 1.8; font-weight: 300; margin-top: 0.75rem; }
.how-steps {
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: 1px; background: var(--border); border: 1px solid var(--border); overflow: hidden;
  clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
}
.how-step { background: var(--surface); padding: 2.25rem 2rem; transition: background 0.2s; position: relative; }
.how-step:hover { background: var(--surface-2); }
.step-num {
  font-family: var(--display); font-weight: 800; font-size: 3.5rem;
  line-height: 1; letter-spacing: 0.02em;
  color: var(--surface-3); margin-bottom: 1.5rem; transition: color 0.2s;
}
.how-step:hover .step-num { color: rgba(34,211,238,0.15); }
.how-step h4 {
  font-family: var(--display); font-weight: 700; font-size: 0.95rem;
  text-transform: uppercase; letter-spacing: 0.08em;
  color: var(--white); margin-bottom: 0.6rem;
}
.how-step p { font-size: 0.83rem; color: var(--muted); line-height: 1.65; font-weight: 300; }

/* WHY */
.why-section { background: var(--deep); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 7rem 3rem; }
.why-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 7rem; align-items: start; }
.why-left { position: sticky; top: 80px; }
.why-body { color: var(--silver); font-size: 0.95rem; line-height: 1.85; font-weight: 300; margin-bottom: 2rem; }
.why-list { list-style: none; }
.why-item {
  border-top: 1px solid var(--border-soft); padding: 1.6rem 0;
  display: grid; grid-template-columns: 1.75rem 1fr; gap: 1rem; align-items: start;
}
.why-item:last-child { border-bottom: 1px solid var(--border-soft); }
.why-dot {
  width: 5px; height: 5px; background: var(--blue-bright); border-radius: 50%;
  margin-top: 0.6rem; box-shadow: 0 0 8px rgba(34,211,238,0.8);
}
.why-title {
  font-family: var(--display); font-weight: 700; font-size: 0.95rem;
  text-transform: uppercase; letter-spacing: 0.06em;
  color: var(--white); margin-bottom: 0.35rem;
}
.why-desc { font-size: 0.84rem; color: var(--muted); line-height: 1.65; font-weight: 300; }

/* INDUSTRIES */
.industries-section { padding: 7rem 3rem; border-bottom: 1px solid var(--border-soft); }
.industries-top { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; margin-bottom: 3.5rem; align-items: end; }
.industries-desc { color: var(--silver); font-size: 0.95rem; line-height: 1.8; font-weight: 300; }
.industry-grid {
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: 1px; background: var(--border); border: 1px solid var(--border); overflow: hidden;
  clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
}
.industry-card {
  background: var(--surface); padding: 1.5rem 1.75rem;
  transition: background 0.2s; position: relative; overflow: hidden; cursor: default;
}
.industry-card::before {
  content: '';
  position: absolute; bottom: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, rgba(200,215,230,0.4), transparent);
  transform: scaleX(0); transform-origin: center; transition: transform 0.3s;
}
.industry-card:hover { background: var(--surface-2); }
.industry-card:hover::before { transform: scaleX(1); }
.industry-name {
  font-family: var(--display); font-weight: 700; font-size: 0.9rem;
  text-transform: uppercase; letter-spacing: 0.06em;
  color: var(--white); margin-bottom: 0.3rem;
}
.industry-note { font-size: 0.75rem; color: var(--muted); line-height: 1.4; font-weight: 300; }
.industries-footer {
  margin-top: 2rem; text-align: center;
  color: var(--muted); font-size: 0.83rem; font-weight: 300;
}
.industries-footer a { color: var(--blue-bright); text-decoration: none; }
.industries-footer a:hover { text-decoration: underline; }

/* TEAM */
.team-section { background: var(--deep); border-top: 1px solid var(--border); padding: 7rem 3rem; }
.team-header { max-width: 660px; margin-bottom: 4rem; }
.team-header .lead { color: var(--silver); font-size: 0.95rem; line-height: 1.85; font-weight: 300; margin-top: 0.75rem; }
.team-grid {
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: 1px; background: var(--border); border: 1px solid var(--border); overflow: hidden;
  clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
}
.team-card { background: var(--surface); display: flex; flex-direction: column; transition: background 0.2s; }
.team-card:hover { background: var(--surface-2); }
.team-photo {
  width: 100%; aspect-ratio: 4/5;
  background: var(--surface-2); border-bottom: 1px solid var(--border);
  display: flex; align-items: center; justify-content: center;
  position: relative; overflow: hidden;
}
.team-photo img {
  width: 100%; height: 100%; object-fit: cover; object-position: center top; display: block;
  transition: transform 0.5s ease; filter: grayscale(15%);
}
.team-card:hover .team-photo img { transform: scale(1.04); filter: grayscale(0%); }
.team-initials {
  position: absolute; inset: 0;
  display: flex; align-items: center; justify-content: center;
  font-family: var(--display); font-weight: 800; font-size: 2.5rem;
  color: var(--blue-bright); letter-spacing: 0.08em; text-transform: uppercase;
  background: linear-gradient(160deg, var(--surface-2) 0%, var(--surface-3) 100%);
}
.team-photo img.has-src + .team-initials { display: none; }
.team-info { padding: 1.5rem; flex: 1; }
.team-name {
  font-family: var(--display); font-weight: 700; font-size: 1.05rem;
  text-transform: uppercase; letter-spacing: 0.06em;
  color: var(--white); margin-bottom: 0.2rem;
}
.team-role {
  font-family: var(--mono); font-size: 0.65rem; color: var(--blue-bright);
  letter-spacing: 0.14em; text-transform: uppercase; opacity: 0.8; margin-bottom: 0.9rem;
}
.team-bio { font-size: 0.82rem; color: var(--muted); line-height: 1.65; font-weight: 300; }

/* CTA */
.cta-section {
  padding: 8rem 3rem; text-align: center;
  position: relative; overflow: hidden;
  border-top: 1px solid var(--border);
}
.cta-section::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(ellipse 65% 65% at 50% 50%, rgba(126,184,212,0.07) 0%, transparent 68%);
  pointer-events: none;
}
.cta-section h2 {
  font-size: clamp(2.5rem, 4.5vw, 4rem); max-width: 700px;
  margin: 0 auto 1.25rem; position: relative;
}
.cta-sub {
  color: var(--silver); font-size: 0.95rem; max-width: 460px;
  margin: 0 auto 2.75rem; line-height: 1.8; font-weight: 300; position: relative;
}
.cta-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; position: relative; }
.cta-meta {
  margin-top: 1.75rem; font-family: var(--mono); font-size: 0.68rem;
  color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; position: relative;
}

/* FOOTER */
footer {
  border-top: 1px solid var(--border); padding: 2.5rem 3rem;
  display: flex; justify-content: space-between; align-items: center;
  flex-wrap: wrap; gap: 1.5rem; background: var(--black);
}
.footer-left { display: flex; align-items: center; gap: 1.5rem; }
.footer-logo {
  font-family: var(--display); font-weight: 800; font-size: 1rem;
  letter-spacing: 0.14em; text-transform: uppercase; color: var(--white);
}
.footer-logo span { color: var(--blue-bright); }
.footer-divider { width: 1px; height: 18px; background: var(--border-soft); }
.footer-tagline { font-family: var(--mono); font-size: 0.65rem; color: var(--muted); letter-spacing: 0.12em; text-transform: uppercase; }
.footer-links { display: flex; gap: 2rem; list-style: none; flex-wrap: wrap; }
.footer-links a {
  color: var(--muted); text-decoration: none;
  font-family: var(--mono); font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase;
  transition: color 0.2s;
}
.footer-links a:hover { color: var(--blue-bright); }
.footer-copy { color: var(--muted); font-size: 0.68rem; font-family: var(--mono); letter-spacing: 0.06em; }

/* REVEAL */
.reveal { opacity: 0; transform: translateY(20px); transition: opacity 0.65s ease, transform 0.65s ease; }
.reveal.in { opacity: 1; transform: none; }
.reveal-left { opacity: 0; transform: translateX(-20px); transition: opacity 0.65s ease, transform 0.65s ease; }
.reveal-left.in { opacity: 1; transform: none; }
.reveal-right { opacity: 0; transform: translateX(20px); transition: opacity 0.65s ease, transform 0.65s ease; }
.reveal-right.in { opacity: 1; transform: none; }

/* RESPONSIVE */
@media (max-width: 1200px) {
  .team-grid { grid-template-columns: repeat(2, 1fr); }
  .industry-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 1000px) {
  .hero { grid-template-columns: 1fr; }
  .hero-right { display: none; }
  .hero-left { padding: 5rem 1.5rem; }
  .how-steps { grid-template-columns: repeat(2, 1fr); }
  .rilbots-inner, .mission-inner, .why-inner,
  .services-header, .industries-top { grid-template-columns: 1fr; gap: 2.5rem; }
  .why-left { position: static; }
  .services-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 900px) {
  nav { padding: 0 1.5rem; }
  .nav-links { display: none; }
  .nav-phone { display: none; }
  .section, .rilbots-section, .mission-section, .services-section,
  .how-section, .why-section, .industries-section, .team-section, .cta-section { padding: 5rem 1.5rem; }
  .stats { grid-template-columns: repeat(2, 1fr); }
  .stat-item { border-right: none; border-bottom: 1px solid var(--border); }
  .stat-item:nth-child(odd) { border-right: 1px solid var(--border); }
  .stat-item:last-child { border-bottom: none; }
  footer { flex-direction: column; gap: 1.25rem; }
}
@media (max-width: 640px) {
  .services-grid { grid-template-columns: 1fr; }
  .how-steps { grid-template-columns: 1fr; }
  .industry-grid { grid-template-columns: repeat(2, 1fr); }
  .team-grid { grid-template-columns: 1fr 1fr; }
  .mission-pillars { grid-template-columns: 1fr; }
}
@media (max-width: 440px) {
  .team-grid { grid-template-columns: 1fr; }
}
</style>
</head>
<body>

<nav>
  <a href="#" class="nav-logo">
    <img class="nav-logo-icon" src="data:image/png;base64," alt="Rip It Labs">
  </a>
